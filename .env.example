# Owner A — .env.example
#
# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env — it is in .gitignore.
# All secrets are seeded into Vault by vault/init.sh at startup.
# The application reads secrets from Vault, not directly from environment variables,
# except for the variables listed below which bootstrap the Vault connection itself.

# ── Postgres ──────────────────────────────────────────────────────────────────
# Password for the concierge database user.
# Must match what Vault seeds at secret/db/password.
POSTGRES_PASSWORD=changeme

# ── MinIO (blob storage) ──────────────────────────────────────────────────────
# Dev defaults — change before any real deployment.
# Used by the tenant erasure flow to delete objects under tenants/{tenant_id}/.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Vault ─────────────────────────────────────────────────────────────────────
# Dev mode only — root token gives full access.
# In production: use a token tied to the concierge-api policy in api.hcl.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ── Environment ───────────────────────────────────────────────────────────────
# Controls log level, debug mode, and other environment-specific behaviour.
# Values: development | staging | production
ENVIRONMENT=development

# ── LLM and embedding API keys ────────────────────────────────────────────────
# These are written into Vault by vault/init.sh as empty strings on Day 1.
# Update them directly in Vault (vault kv put secret/llm/api_key key=sk-ant-...)
# rather than here. These env vars are only needed if you want to override
# the Vault value during local development without restarting Vault.
# ANTHROPIC_API_KEY=sk-ant-...
